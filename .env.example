# Local development only. Copy to `.env` and fill in real values.
# `.env` is gitignored. In production these come from Google Secret
# Manager instead (see src/config/loadSecrets.js), NOT from this file.

JWT_SECRET=
EMAIL_USER=
EMAIL_PASS=
MONGO_URI=
GOOGLE_SPREAD_SHEET_ID=
# Keep the literal \n sequences in the private key on a single line.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_CLIENT_EMAIL=
